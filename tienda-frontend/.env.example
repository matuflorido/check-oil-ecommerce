# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# MercadoPago Integration
VITE_MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key

# Store Configuration
VITE_STORE_NAME=Check-Oil Tienda
VITE_STORE_CURRENCY=ARS

# Application Settings
VITE_APP_ENV=development
VITE_ENABLE_ANALYTICS=false

# Session & Storage
VITE_SESSION_TIMEOUT=3600000
VITE_STORAGE_PREFIX=check_oil_tienda_

# Features
VITE_ENABLE_GUEST_CHECKOUT=true
VITE_ENABLE_LOYALTY_PROGRAM=true

# Theme
VITE_PRIMARY_COLOR=#F78E1E
VITE_DARK_MODE=true
