{
  "name": "check-oil-backend",
  "version": "1.0.0",
  "description": "Check-Oil ecommerce platform - Backend API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "migrate": "node migrate.mjs",
    "seed": "node seed.mjs",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "ecommerce",
    "lubricants",
    "auto-accessories"
  ],
  "author": "Check-Oil Team",
  "license": "ISC",
  "dependencies": {
    "@sendgrid/mail": "^8.0.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.0",
    "cloudinary": "^1.40.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.10.0",
    "jsonwebtoken": "^9.0.0",
    "mercadopago": "^2.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.10.0",
    "sequelize": "^6.35.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^30.4.2",
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.5.2",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
